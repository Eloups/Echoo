# ici il faut mettre l'adresse IP locale du pc 
# allé dans le terminal et tapez ipconfig (windows) 
# et prendre l'adresse IPv4 et remplacé le localhost dans les url 
# avec Android studio c'est 10.0.2.2

# Configuration de l'API Backend
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Configuration du serveur de fichiers
EXPO_PUBLIC_FILE_SERVER_URL=http://localhost:8080

# Url de du service d'autentification
EXPO_PUBLIC_API_AUTH_URL=http://localhost:3333