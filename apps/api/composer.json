{
    "name": "echoo/api",
    "description": "Une application musicale communautaire innovante permettant d'\u00e9couter de la musique et de la partager avec ses amis !",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Api\\": [
                "src/router"
            ],
            "Api\\Controller\\": "src/controller",
            "Api\\Domain\\Class\\": "src/domain/class",
            "Api\\Domain\\Service\\": "src/domain/service",
            "Api\\Domain\\Ports\\": "src/domain/ports",
            "Api\\Adapter\\": [
                "src/adapter/driving",
                "src/adapter/driven"
            ],
            "Api\\Adapter\\DTO\\": "src/adapter/driving/dto",
            "Api\\Utils\\": "src/utils",
            "Api\\Database\\": "src/database",
            "Api\\Database\\Requests\\": "src/database/requests",
            "Api\\Exception\\": "src/errors"
        }
    },
    "authors": [
        {
            "name": "Elouan TISSIER",
            "email": "121400663+Eloups@users.noreply.github.com"
        },
        {
            "name": "Corentin SCHEER"
        },
        {
            "name": "Romain DURAND"
        },
        {
            "name": "Thibault CALLERAND"
        }
    ],
    "require": {
        "symfony/routing": "^7.3",
        "symfony/http-foundation": "^7.3",
        "symfony/serializer-pack": "^1.3",
        "symfony/dotenv": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.3",
        "symfony/var-dumper": "^7.4",
        "codeception/codeception": "^5.3",
        "codeception/module-phpbrowser": "*",
        "codeception/module-asserts": "*",
        "codeception/module-rest": "^3.4",
        "pestphp/pest-plugin-stressless": "^4.0",
        "pestphp/pest": "^4.3",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "test": [
            "composer docker_start",
            "composer unit_test",
            "composer e2e_test",
            "composer docker_drop"
        ],
        "unit_test": "./vendor/bin/phpunit ./tests/unit/",
        "e2e_test": [
            "php vendor/bin/codecept build",
            "php vendor/bin/codecept run"
        ],
        "perf_test": "./vendor/bin/pest tests/perf/ApiPerfTest.php",
        "full_perf_test": "./vendor/bin/pest tests/perf/ApiFullPerfTest.php",
        "docker_start": "docker-compose up -d",
        "docker_stop": "docker-compose stop",
        "docker_drop": "docker-compose down -v",
        "lint": "vendor/bin/phpstan analyse public src tests -l 1"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}