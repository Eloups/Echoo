# Ceci est un exemple de fichier .env
# Remplacez ces valeurs pour la connexion à la base de données postgreSQL
DB_HOST=database_host
DB_PORT=database_port
DB_NAME=database_name
DB_USER=database_username
DB_PASSWORD=database_password

# Remplacez ces valeurs pour la connexion à votre serveur de fichiers
FS_HOST=https://exemple.domain.com
FS_PORT=your_port

# Remplacez ces valeurs pour la connexion à votre service d'authentification
AUTH_SERVICE_URL=http://your_local_ip:3333
